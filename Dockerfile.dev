# Development Dockerfile for Etheria Times
FROM node:20-alpine

WORKDIR /app

# Install system dependencies
RUN apk add --no-cache \
    wget \
    ca-certificates \
    curl \
    git \
    bash \
    build-base \
    libc6-compat

# Install Go (multi-arch)
RUN ARCH=$(uname -m) && \
    case "$ARCH" in \
        x86_64)  GOARCH="amd64" ;; \
        aarch64) GOARCH="arm64" ;; \
        *) echo "Unsupported arch: $ARCH" && exit 1 ;; \
    esac && \
    wget -q "https://go.dev/dl/go1.24.2.linux-${GOARCH}.tar.gz" -O /tmp/go.tar.gz \
    && tar -C /usr/local -xzf /tmp/go.tar.gz \
    && rm /tmp/go.tar.gz

ENV PATH="/usr/local/go/bin:/go/bin:/root/go/bin:${PATH}"
ENV GOPATH="/go"

# Copy Go module files
COPY go.mod go.sum* ./

# Download Go modules
RUN go mod download

# Install Air for hot-reload
RUN go install github.com/air-verse/air@latest

# Copy Next.js app package files
COPY app/package.json app/pnpm-lock.yaml* ./app/

# Enable pnpm and install dependencies (version épinglée)
WORKDIR /app/app
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate && pnpm install

# Copy Next.js source files
COPY app/app/ ./app/
COPY app/components/ ./components/
COPY app/config/ ./config/
COPY app/context/ ./context/
COPY app/hooks/ ./hooks/
COPY app/lib/ ./lib/
COPY app/public/ ./public/
COPY app/styles/ ./styles/
COPY app/package.json ./
COPY app/tsconfig.json ./
COPY app/next.config.ts ./
COPY app/postcss.config.mjs ./
COPY app/components.json ./
COPY app/eslint.config.mjs ./
COPY app/proxy.ts ./ 

# Copy Go server files
WORKDIR /app
COPY server/ ./server/

# Copy Air config and env
COPY .air.toml ./
COPY .env.example ./.env

# Create entrypoint script
RUN echo '#!/bin/sh' > /entrypoint.sh && \
    echo 'set -e' >> /entrypoint.sh && \
    echo '' >> /entrypoint.sh && \
    echo 'echo "=========================================="' >> /entrypoint.sh && \
    echo 'echo "  Etheria Times - Services Starting"' >> /entrypoint.sh && \
    echo 'echo "  - Frontend: http://localhost:3000"' >> /entrypoint.sh && \
    echo 'echo "  - API:      http://localhost:8080"' >> /entrypoint.sh && \
    echo 'echo "  - DB:       localhost:5432 (external)"' >> /entrypoint.sh && \
    echo 'echo "=========================================="' >> /entrypoint.sh && \
    echo 'echo ""' >> /entrypoint.sh && \
    echo '' >> /entrypoint.sh && \
    echo 'cd /app/server' >> /entrypoint.sh && \
    echo 'echo "[*] Starting Go API server on :8080..."' >> /entrypoint.sh && \
    echo 'air -c /app/.air.toml & API_PID=$!' >> /entrypoint.sh && \
    echo '' >> /entrypoint.sh && \
    echo 'cd /app/app' >> /entrypoint.sh && \
    echo 'echo "[*] Starting Next.js on :3000..."' >> /entrypoint.sh && \
    echo 'pnpm dev & NEXT_PID=$!' >> /entrypoint.sh && \
    echo '' >> /entrypoint.sh && \
    echo 'echo "[*] All services started! Press Ctrl+C to stop"' >> /entrypoint.sh && \
    echo '' >> /entrypoint.sh && \
    echo 'trap "echo '\''[*] Stopping services...'\''; kill $API_PID $NEXT_PID 2>/dev/null; exit 0" SIGINT SIGTERM' >> /entrypoint.sh && \
    echo '' >> /entrypoint.sh && \
    echo 'wait' >> /entrypoint.sh

RUN chmod +x /entrypoint.sh

EXPOSE 3000 8080

ENTRYPOINT ["/entrypoint.sh"]